---
---

<header
  class="absolute w-full flex justify-between items-center px-6 py-4 z-50"
>
  <!-- Logo -->
  <a href="#inicio" class="z-50 flex-shrink-0">
    <img
      src="/img/CaribeHospitalitySVGGrey.svg"
      alt="Caribe Hospitality"
      width="200"
      height="55"
      class="h-10 w-auto"
    />
  </a>

  <!-- Desktop Nav -->
  <nav class="hidden md:flex items-center gap-1">
    <a
      href="#inicio"
      class="text-white font-medium px-4 py-2 rounded-lg hover:bg-white/10 transition-colors duration-200"
      data-i18n="inicio">Inicio</a
    >
    <a
      href="#vision"
      class="text-white font-medium px-4 py-2 rounded-lg hover:bg-white/10 transition-colors duration-200"
      data-i18n="about">¿Quiénes Somos?</a
    >
    <a
      href="#sostenibilidad"
      class="text-white font-medium px-4 py-2 rounded-lg hover:bg-white/10 transition-colors duration-200"
      data-i18n="sustainability">Sostenibilidad</a
    >
    <a
      href="#proyectos"
      class="text-white font-medium px-4 py-2 rounded-lg hover:bg-white/10 transition-colors duration-200"
      data-i18n="portfolio">Portafolio</a
    >
    <button
      id="lang-toggle"
      class="ml-2 text-white border border-white/60 rounded-lg px-4 py-2 font-medium hover:bg-white hover:text-gray-900 transition-all duration-300 animate-pulse"
      data-i18n="currentLang"
    >
      ENG
    </button>
  </nav>

  <!-- Mobile hamburger -->
  <button
    id="menu-btn"
    class="md:hidden z-50 text-white p-2 rounded-lg hover:bg-white/10 transition-colors"
    aria-label="Abrir menú"
  >
    <svg
      id="icon-open"
      xmlns="http://www.w3.org/2000/svg"
      class="h-6 w-6"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M4 6h16M4 12h16M4 18h16"></path>
    </svg>
    <svg
      id="icon-close"
      xmlns="http://www.w3.org/2000/svg"
      class="h-6 w-6 hidden"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="fixed inset-0 bg-black/95 flex flex-col items-center justify-center gap-8 z-40 translate-x-full transition-transform duration-500 ease-in-out md:hidden"
  >
    <a
      href="#inicio"
      class="text-white text-3xl font-bold hover:text-[#6AAB33] transition-colors"
      data-i18n="inicio">Inicio</a
    >
    <a
      href="#vision"
      class="text-white text-3xl font-bold hover:text-[#6AAB33] transition-colors"
      data-i18n="about">¿Quiénes Somos?</a
    >
    <a
      href="#sostenibilidad"
      class="text-white text-3xl font-bold hover:text-[#6AAB33] transition-colors"
      data-i18n="sustainability">Sostenibilidad</a
    >
    <a
      href="#proyectos"
      class="text-white text-3xl font-bold hover:text-[#6AAB33] transition-colors"
      data-i18n="portfolio">Portafolio</a
    >
    <button
      id="lang-toggle-mobile"
      class="text-white border border-white rounded-xl px-6 py-3 text-lg font-bold hover:bg-white hover:text-gray-900 transition-all duration-300 animate-pulse"
      data-i18n="currentLang"
    >
      ENG
    </button>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  function toggleMenu() {
    const isOpen = !mobileMenu.classList.contains('translate-x-full');
    if (isOpen) {
      mobileMenu.classList.add('translate-x-full');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      document.body.style.overflow = '';
    } else {
      mobileMenu.classList.remove('translate-x-full');
      iconOpen.classList.add('hidden');
      iconClose.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
  }

  menuBtn.addEventListener('click', toggleMenu);

  // Close menu when clicking a link
  mobileMenu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('translate-x-full');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      document.body.style.overflow = '';
    });
  });

  // Language toggle
  function fireLangToggle() {
    document.dispatchEvent(new Event('ch:toggle-lang'));
  }

  document.getElementById('lang-toggle')?.addEventListener('click', fireLangToggle);
  document.getElementById('lang-toggle-mobile')?.addEventListener('click', fireLangToggle);
</script>
