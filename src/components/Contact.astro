---
---

<section id="contacto" class="py-24 px-6 bg-gray-900 text-white" data-reveal aria-labelledby="contact-heading">
  <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-16 items-center">

    <!-- Left: texto -->
    <div class="space-y-6">
      <h2 id="contact-heading" class="text-3xl md:text-4xl font-bold leading-tight">
        <span class="text-[#6AAB33]" data-i18n="contactHeading">¿Tiene un proyecto</span><br />
        <span data-i18n="contactHeading2">hotelero en mente?</span>
      </h2>
      <p class="text-gray-400 leading-relaxed" data-i18n="contactText">
        Estamos siempre en búsqueda de nuevas oportunidades de inversión y desarrollo hotelero en la región. Contáctenos para explorar posibilidades juntos.
      </p>
      <div class="space-y-3 text-sm text-gray-400">
        <a href="mailto:info@caribehospitality.com" class="flex items-center gap-3 hover:text-white transition-colors group">
          <span class="w-9 h-9 bg-[#6AAB33]/20 rounded-lg flex items-center justify-center group-hover:bg-[#6AAB33]/40 transition-colors">
            <svg class="w-4 h-4 text-[#6AAB33]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </span>
          info@caribehospitality.com
        </a>
        <a href="tel:+50622088890" class="flex items-center gap-3 hover:text-white transition-colors group">
          <span class="w-9 h-9 bg-[#6AAB33]/20 rounded-lg flex items-center justify-center group-hover:bg-[#6AAB33]/40 transition-colors">
            <svg class="w-4 h-4 text-[#6AAB33]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </span>
          +(506) 2208-8890 — Costa Rica
        </a>
        <a href="https://www.linkedin.com/company/caribehospitality/" target="_blank" rel="noreferrer" class="flex items-center gap-3 hover:text-white transition-colors group">
          <span class="w-9 h-9 bg-[#6AAB33]/20 rounded-lg flex items-center justify-center group-hover:bg-[#6AAB33]/40 transition-colors">
            <img src="/img/linkedinLogo.svg" alt="LinkedIn" class="w-4 h-4" />
          </span>
          LinkedIn — Caribe Hospitality
        </a>
      </div>
    </div>

    <!-- Right: formulario -->
    <form
      id="contact-form"
      action="mailto:info@caribehospitality.com"
      method="GET"
      class="space-y-4"
    >
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-gray-400 mb-1 uppercase tracking-wide" data-i18n="contactName">Nombre</label>
          <input
            type="text"
            name="name"
            required
            class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm placeholder-gray-600 focus:outline-none focus:border-[#6AAB33] transition-colors"
            placeholder="Juan Pérez"
          />
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-1 uppercase tracking-wide" data-i18n="contactEmail">Correo</label>
          <input
            type="email"
            name="email"
            required
            class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm placeholder-gray-600 focus:outline-none focus:border-[#6AAB33] transition-colors"
            placeholder="juan@empresa.com"
          />
        </div>
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-1 uppercase tracking-wide" data-i18n="contactSubject">Asunto</label>
        <input
          type="text"
          name="subject"
          required
          class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm placeholder-gray-600 focus:outline-none focus:border-[#6AAB33] transition-colors"
          placeholder="Oportunidad de inversión hotelera"
        />
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-1 uppercase tracking-wide" data-i18n="contactMessage">Mensaje</label>
        <textarea
          name="body"
          rows="4"
          required
          class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm placeholder-gray-600 focus:outline-none focus:border-[#6AAB33] transition-colors resize-none"
          placeholder="Cuéntenos sobre su proyecto..."></textarea>
      </div>
      <button
        type="submit"
        class="w-full bg-[#6AAB33] hover:bg-[#5a9428] text-white font-bold py-3 rounded-xl transition-colors duration-200 text-sm tracking-wide"
        data-i18n="contactSend"
      >
        Enviar Mensaje →
      </button>
    </form>
  </div>
</section>
