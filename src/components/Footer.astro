---
const year = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-300">
  <div class="max-w-6xl mx-auto px-6 py-14 grid md:grid-cols-3 gap-10">
    <!-- Logo -->
    <div class="flex flex-col gap-4">
      <img
        src="/img/CaribeHospitalitySVGGrey.svg"
        alt="Caribe Hospitality"
        width="180"
        height="50"
        class="h-10 w-auto brightness-0 invert opacity-80"
      />
      <p class="text-sm text-gray-500 leading-relaxed">
        Desarrollador hotelero líder en la región Caribe y Latinoamérica.
      </p>
      <!-- LinkedIn -->
      <a
        href="https://www.linkedin.com/company/caribehospitality/"
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors mt-1"
        aria-label="LinkedIn"
      >
        <img src="/img/linkedinLogo.svg" alt="LinkedIn" class="w-7 h-7 rounded opacity-80 hover:opacity-100 transition-opacity" />
        <span class="text-sm"></span>
      </a>
    </div>

    <!-- Costa Rica -->
    <div>
      <h4 class="text-white font-bold mb-4 text-sm uppercase tracking-widest">Costa Rica</h4>
      <ul class="space-y-2 text-sm">
        <li class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[#6AAB33] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          +(506) 2208-8890
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[#6AAB33] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          info@caribehospitality.com
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 text-[#6AAB33] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span>205 Avenida Escazú, Piso 5, Suite 5,<br />10203 San José, Escazú,<br />San José, Costa Rica</span>
        </li>
      </ul>
    </div>

    <!-- México -->
    <div>
      <h4 class="text-white font-bold mb-4 text-sm uppercase tracking-widest">México</h4>
      <ul class="space-y-2 text-sm">
        <li class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[#6AAB33] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          +52 (55) 46313338
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[#6AAB33] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          info@caribehospitality.com
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 text-[#6AAB33] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span>Av. Del Imán #151, Int A110, Piso 1,<br />Suite B-38, Col. Pedregal De Carrasco.<br />México CDMX 04700</span>
        </li>
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-gray-800 py-4 px-6">
    <a href="https://revify.cr" target="_blank" rel="noreferrer" class="block text-center text-xs text-gray-600 hover:text-gray-400 transition-colors">
      <span data-i18n="copyRight">Derechos reservados Caribe Hospitality.</span>
      &nbsp;Revify © {year}
    </a>
  </div>
</footer>
