---
interface Hotel {
  name: string;
  shortName: string;
  year: number;
  rooms: number;
  img: string;
  url: string;
  country: string;
}

const hotels: Hotel[] = [
  { name: 'AC Hotel by Marriott San José Escazú, Costa Rica', shortName: 'AC Hotel by Marriott Escazú', year: 2018, rooms: 126, img: '/img/exterior1_final.png', url: 'https://www.marriott.com/en-us/hotels/sjoar-ac-hotel-san-jose-escazu/overview/', country: 'Costa Rica' },
  { name: 'Residence Inn by Marriott San Jose Escazú, Costa Rica', shortName: 'Residence Inn Escazú', year: 2009, rooms: 109, img: '/img/residenceinn.jpg', url: 'https://www.marriott.com/en-us/hotels/sjori-residence-inn-san-jose-escazu/overview/', country: 'Costa Rica' },
  { name: 'Fairfield by Marriott San Jose Airport Alajuela, Costa Rica', shortName: 'Fairfield Alajuela', year: 2022, rooms: 120, img: '/img/fairfield.jpeg', url: 'https://www.marriott.com/en-us/hotels/sjofa-fairfield-by-marriott-san-jose-airport-alajuela/overview/', country: 'Costa Rica' },
  { name: 'Courtyard by Marriott San José Airport Alajuela, Costa Rica', shortName: 'Courtyard Alajuela', year: 2012, rooms: 127, img: '/img/courtyardcr.webp', url: 'https://www.marriott.com/en-us/hotels/sjoap-courtyard-san-jose-airport-alajuela/overview/', country: 'Costa Rica' },
  { name: 'Hyatt Place San José Pinares, Costa Rica', shortName: 'Hyatt Place Pinares', year: 2012, rooms: 120, img: '/img/hyattPlace.jpg', url: 'https://www.hyatt.com/en-US/hotel/costa-rica/hyatt-place-san-jose-pinares/sjozp', country: 'Costa Rica' },
  { name: 'Courtyard by Marriott Kingston, Jamaica', shortName: 'Courtyard Kingston', year: 2015, rooms: 129, img: '/img/courtyardKingston.webp', url: 'https://www.marriott.com/en-us/hotels/kincy-courtyard-kingston-jamaica/overview/', country: 'Jamaica' },
  { name: 'Courtyard by Marriott Hermosillo, México', shortName: 'Courtyard Hermosillo', year: 2016, rooms: 133, img: '/img/CYHER.jpg', url: 'https://www.marriott.com/en-us/hotels/hmocy-courtyard-hermosillo/overview/', country: 'México' },
  { name: 'Courtyard by Marriott León at The Poliforum, México', shortName: 'Courtyard León', year: 2013, rooms: 140, img: '/img/courtyardLeon.webp', url: 'https://www.marriott.com/en-us/hotels/bjxcy-courtyard-leon-at-the-poliforum/overview/', country: 'México' },
  { name: 'Courtyard by Marriott San Salvador, El Salvador', shortName: 'Courtyard San Salvador', year: 2007, rooms: 133, img: '/img/courtyardSalvador.webp', url: 'https://www.marriott.com/en-us/hotels/salcy-courtyard-san-salvador/overview', country: 'El Salvador' },
  { name: 'Fairfield by Marriott San Salvador, El Salvador', shortName: 'Fairfield San Salvador', year: 2017, rooms: 130, img: '/img/fairfieldSalvador.jpg', url: 'https://www.marriott.com/en-us/hotels/salfi-fairfield-by-marriott-san-salvador/overview/', country: 'El Salvador' },
  { name: 'Courtyard by Marriott Bridgetown, Barbados', shortName: 'Courtyard Barbados', year: 2012, rooms: 118, img: '/img/courtyardBarbados.webp', url: 'https://www.marriott.com/en-us/hotels/bgicy-courtyard-bridgetown-barbados/overview/', country: 'Barbados' },
  { name: 'Hyatt Centric San José Escazú, Costa Rica', shortName: 'Hyatt Centric Escazú', year: 2024, rooms: 161, img: '/img/HyattC.png', url: 'https://www.hyatt.com/hyatt-centric/sjoct-hyatt-centric-san-jose-escazu', country: 'Costa Rica' },
];

const countries = ['Todos', ...Array.from(new Set(hotels.map((h) => h.country)))];
---

<section id="proyectos" class="py-20 px-6 md:px-16 bg-gray-50">
  <div class="max-w-7xl mx-auto">

    <div data-reveal>
      <h2 class="text-3xl md:text-4xl font-bold text-[#6AAB33] text-center mb-2" data-i18n="portfolio">
        Portafolio
      </h2>
      <p class="text-gray-500 text-center mb-8 text-sm tracking-widest uppercase">
        {hotels.length} propiedades activas
      </p>

      <!-- Filtros por país -->
      <div class="flex flex-wrap justify-center gap-2 mb-10" id="filter-btns">
        {countries.map((c) => (
          <button
            data-filter={c}
            class={`filter-btn px-4 py-1.5 rounded-full text-sm font-medium border transition-all duration-200 ${
              c === 'Todos'
                ? 'bg-[#6AAB33] text-white border-[#6AAB33]'
                : 'bg-white text-gray-600 border-gray-200 hover:border-[#6AAB33] hover:text-[#6AAB33]'
            }`}
          >
            {c}
          </button>
        ))}
      </div>
    </div>

    <!-- Grid — mobile: horizontal scroll carousel; md+: grid -->
    <div
      id="hotels-grid"
      class="flex md:grid md:grid-cols-3 xl:grid-cols-4 gap-6 overflow-x-auto md:overflow-visible snap-x snap-mandatory md:snap-none pb-4 md:pb-0 -mx-2 px-2 md:mx-0 md:px-0"
    >
      {hotels.map((hotel) => (
        <a
          href={hotel.url}
          target="_blank"
          rel="noreferrer"
          data-country={hotel.country}
          class="hotel-card group flex-shrink-0 w-72 md:w-auto snap-start block rounded-2xl overflow-hidden bg-white shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
          data-reveal
        >
          <div class="relative overflow-hidden h-52">
            <img
              src={hotel.img}
              alt={hotel.shortName}
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-4">
              <div class="translate-y-4 group-hover:translate-y-0 transition-transform duration-300 space-y-1">
                <div class="flex items-center gap-3 text-white/80 text-sm">
                  <span class="flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <span data-i18n="anio">Año</span>: {hotel.year}
                  </span>
                  <span class="flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
                    </svg>
                    {hotel.rooms}
                  </span>
                </div>
                <span class="inline-block mt-2 border border-white/70 text-white text-xs px-3 py-1 rounded-full" data-i18n="verHotel">
                  Ver Hotel →
                </span>
              </div>
            </div>
            <div class="absolute top-3 right-3">
              <span class="bg-[#6AAB33] text-white text-xs font-semibold px-2 py-1 rounded-full shadow">
                {hotel.country}
              </span>
            </div>
          </div>
          <div class="p-4">
            <p class="text-gray-800 font-medium text-sm leading-snug">{hotel.name}</p>
          </div>
        </a>
      ))}
    </div>

    <!-- No results -->
    <p id="no-results" class="hidden text-center text-gray-400 py-12 text-sm">
      No hay hoteles para este filtro.
    </p>
  </div>
</section>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.hotel-card');
  const noResults = document.getElementById('no-results')!;

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;

      // Update active style
      btns.forEach((b) => {
        b.classList.remove('bg-[#6AAB33]', 'text-white', 'border-[#6AAB33]');
        b.classList.add('bg-white', 'text-gray-600', 'border-gray-200');
      });
      btn.classList.add('bg-[#6AAB33]', 'text-white', 'border-[#6AAB33]');
      btn.classList.remove('bg-white', 'text-gray-600', 'border-gray-200');

      // Show/hide cards
      let visible = 0;
      cards.forEach((card) => {
        const match = filter === 'Todos' || card.dataset.country === filter;
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      noResults.classList.toggle('hidden', visible > 0);
    });
  });
</script>
