---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Caribe Hospitality',
  description = 'Caribe Hospitality — Desarrollador hotelero líder en la región Caribe y Latinoamérica. Más de 16 proyectos en 8 países con Marriott y Hyatt.',
  ogImage = '/img/exterior1_final.png',
} = Astro.props;

const siteUrl = 'https://caribehospitality.com';
const canonicalURL = new URL('/', siteUrl).toString();
const ogImageAbsolute = `${siteUrl}${ogImage}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteUrl}/#organization`,
      name: 'Caribe Hospitality',
      url: siteUrl,
      logo: {
        '@type': 'ImageObject',
        url: `${siteUrl}/img/CaribeHospitalitySVGGrey.svg`,
        width: 600,
        height: 165,
      },
      description:
        'Desarrollador hotelero líder en la región Caribe y Latinoamérica. Más de 16 proyectos en 8 países con las mejores marcas del mundo.',
      areaServed: ['Costa Rica', 'México', 'Jamaica', 'El Salvador', 'Barbados', 'Puerto Rico', 'Trinidad y Tobago', 'República Dominicana'],
      sameAs: ['https://www.linkedin.com/company/caribehospitality/'],
      email: 'info@caribehospitality.com',
      contactPoint: [
        {
          '@type': 'ContactPoint',
          telephone: '+506-2208-8890',
          contactType: 'customer service',
          areaServed: 'CR',
          availableLanguage: ['Spanish', 'English'],
        },
        {
          '@type': 'ContactPoint',
          telephone: '+52-55-46313338',
          contactType: 'customer service',
          areaServed: 'MX',
          availableLanguage: ['Spanish'],
        },
      ],
      address: {
        '@type': 'PostalAddress',
        streetAddress: '205 Avenida Escazú, Piso 5, Suite 5',
        addressLocality: 'Escazú',
        addressRegion: 'San José',
        postalCode: '10203',
        addressCountry: 'CR',
      },
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      url: siteUrl,
      name: 'Caribe Hospitality',
      publisher: { '@id': `${siteUrl}/#organization` },
      inLanguage: ['es', 'en'],
    },
    {
      '@type': 'WebPage',
      '@id': `${canonicalURL}#webpage`,
      url: canonicalURL,
      name: title,
      description,
      isPartOf: { '@id': `${siteUrl}/#website` },
      about: { '@id': `${siteUrl}/#organization` },
      inLanguage: 'es',
    },
  ],
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO Primary -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Caribe Hospitality" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="AC Hotel by Marriott Escazú — Caribe Hospitality" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="es_CR" />
    <meta property="og:locale:alternate" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />
    <meta name="twitter:image:alt" content="AC Hotel by Marriott Escazú — Caribe Hospitality" />

    <!-- PWA / Favicon -->
    <link rel="icon" type="image/svg+xml" href="/img/faviconCaribeH.svg" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#6AAB33" />
    <meta name="color-scheme" content="light" />

    <!-- Preload critical resources -->
    <link rel="preload" as="image" href="/img/exterior1_final.png" fetchpriority="high" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,700&display=swap"
      />
    </noscript>

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <style>
      /* Scroll reveal */
      [data-reveal] {
        opacity: 0;
        transform: translateY(28px);
        transition: opacity 0.65s ease, transform 0.65s ease;
      }
      [data-reveal].is-visible {
        opacity: 1;
        transform: translateY(0);
      }
      [data-reveal-delay="1"] { transition-delay: 0.1s; }
      [data-reveal-delay="2"] { transition-delay: 0.2s; }
      [data-reveal-delay="3"] { transition-delay: 0.3s; }
    </style>
  </head>
  <body class="bg-white text-gray-900">
    <slot />
  </body>
</html>

<script>
  import { translations } from '../i18n/translations';
  type Lang = 'es' | 'en';

  function applyLang(lang: Lang) {
    const t = translations[lang];
    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n') as keyof typeof t;
      if (t[key] !== undefined) el.textContent = t[key];
    });
    document.documentElement.lang = lang;
    localStorage.setItem('ch-lang', lang);
  }

  const saved = (localStorage.getItem('ch-lang') as Lang) || 'es';
  applyLang(saved);

  document.addEventListener('ch:toggle-lang', () => {
    const current = (localStorage.getItem('ch-lang') as Lang) || 'es';
    applyLang(current === 'es' ? 'en' : 'es');
  });

  // Scroll reveal
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          revealObserver.unobserve(e.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll('[data-reveal]').forEach((el) => revealObserver.observe(el));
</script>
