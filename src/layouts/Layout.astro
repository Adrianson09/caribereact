---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Caribe Hospitality',
  description = 'Caribe Hospitality - Desarrollador hotelero líder en la región',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/img/faviconCaribeH.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,700;1,9..40,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-white text-gray-900">
    <slot />
  </body>
</html>

<script>
  import { translations } from '../i18n/translations';
  type Lang = 'es' | 'en';

  function applyLang(lang: Lang) {
    const t = translations[lang];
    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n') as keyof typeof t;
      if (t[key] !== undefined) el.textContent = t[key];
    });
    document.documentElement.lang = lang;
    localStorage.setItem('ch-lang', lang);
  }

  const saved = (localStorage.getItem('ch-lang') as Lang) || 'es';
  applyLang(saved);

  document.addEventListener('ch:toggle-lang', () => {
    const current = (localStorage.getItem('ch-lang') as Lang) || 'es';
    applyLang(current === 'es' ? 'en' : 'es');
  });
</script>
